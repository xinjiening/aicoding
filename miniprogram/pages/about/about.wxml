<navigation-bar title="我们" back="{{ false }}" color="#2C2C2C" background="#FFF7F8"></navigation-bar>

<scroll-view scroll-y enable-flex class="page-wrap">
  <view class="card">
    <view class="card-title" bindtap="onTitleTap">关于「新杰和白静的家」</view>
    <view class="muted">夫妻共用的家庭仪表盘 · V1 经期助手</view>
  </view>

  <view class="card manage-card">
    <view class="row-between manage-row">
      <view class="manage-copy">
        <view class="card-title no-gap">删除管理</view>
        <view class="muted tiny">开启后，「家」页的备注和大姨妈每一行右侧都会提示长按可删除</view>
      </view>
      <switch color="#E91E63" checked="{{ batchMode }}" bindchange="onBatchModeChange" />
    </view>
  </view>

  <!-- 我的角色 -->
  <view class="card">
    <view class="card-title">我的角色</view>
    <view class="muted tiny">影响首页文案；开发中两人共用一个家庭，互不冲突</view>
    <view class="role-row">
      <view
        class="role-pill {{ user.role === 'husband' ? 'role-on' : '' }}"
        data-role="husband"
        bindtap="onSelectRole"
      >👨 丈夫</view>
      <view
        class="role-pill {{ user.role === 'wife' ? 'role-on' : '' }}"
        data-role="wife"
        bindtap="onSelectRole"
      >👩 老婆</view>
    </view>
    <view wx:if="{{ user && !user.role_manually_set }}" class="hint">
      当前角色使用默认值「老婆」，点击上方可手动切换为丈夫。
    </view>
  </view>

  <!-- 周期长度 -->
  <view class="card">
    <view class="card-title">周期长度</view>
    <view class="row-between">
      <view class="muted">自动估算</view>
      <view class="{{ autoAvgDays === null ? 'muted' : '' }}">{{ autoAvgText }}</view>
    </view>
    <view class="row-between">
      <view class="muted">当前生效</view>
      <view>
        <text>{{ effectiveAvgText }}</text>
        <text wx:if="{{ user.manual_avg_cycle_days }}" class="badge-manual"> 手动</text>
      </view>
    </view>

    <view class="manual-row">
      <input
        class="input"
        type="number"
        placeholder="手动设置 {{ minCycle }}-{{ maxCycle }} 天"
        value="{{ manualInput }}"
        bindinput="onManualInput"
      />
      <button class="btn-primary mini" size="mini" bindtap="onSetManualAvgCycle">保存</button>
    </view>
    <view wx:if="{{ user.manual_avg_cycle_days }}" class="link warn-link" bindtap="onClearManualAvgCycle">
      清除手动设置，恢复自动估算
    </view>
    <view class="hint tiny">
      手动设置后会立即覆盖首页的预测；任意成员都可修改。
    </view>
  </view>

  <!-- 当前身份信息（折叠为只读详情） -->
  <view class="card">
    <view class="card-title">当前身份</view>
    <view wx:if="{{ user }}" class="row-between">
      <view class="muted">家庭 ID</view>
      <view class="tiny">{{ user.family_id }}</view>
    </view>
    <view wx:if="{{ user }}" class="row-between">
      <view class="muted">openid</view>
      <view class="tiny mono">{{ user.openid }}</view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">运行模式</view>
    <view class="row-between">
      <view class="muted">云开发</view>
      <view class="{{ cloudReady ? 'ok' : 'warn' }}">{{ cloudReady ? '已开通' : 'Mock 模式' }}</view>
    </view>
    <view wx:if="{{ !cloudReady }}" class="hint">
      未开通时，所有数据存本地 storage（仅当前设备）。
      开通步骤：
      <view class="step">1. 微信开发者工具 → 顶部「云开发」 → 开通环境，拿 envId</view>
      <view class="step">2. 编辑 <text class="mono" bindtap="onCopyEnv">miniprogram/constants.ts</text>，把 CLOUD_ENV 改成 envId</view>
      <view class="step">3. 在 cloudfunctions/ 下右键每个云函数 → 上传并部署（whoami / ping / home-bundle / data-rw / family-settings）</view>
      <view class="step">4. 云开发控制台 → 数据库，建 2 个集合：families、events，权限设为「仅创建者可读写」</view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">数据导出</view>
    <view class="muted">V1 暂不做产品级导出；可在云开发控制台手动导出 JSON。</view>
    <view class="link" bindtap="onExport">了解详情 ›</view>
  </view>

  <view wx:if="{{ showHidden }}" class="card debug">
    <view class="card-title">🛠 调试菜单（仅 Mock 模式有效）</view>
    <view class="row gap-12 mt">
      <button class="btn-secondary flex" bindtap="onSwitchToHusband">切换：丈夫</button>
      <button class="btn-secondary flex" bindtap="onSwitchToWife">切换：妻子</button>
    </view>
    <button class="btn-ghost mt" bindtap="onResetMock">清空本地 Mock 数据</button>
  </view>

  <view class="footnote">v0.1.0 · 设计文档：<text class="mono">~/.gstack/projects/ai-family/</text></view>
</scroll-view>
