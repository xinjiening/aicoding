<navigation-bar title="我们家" back="{{ false }}" color="#2C2C2C" background="#FFF7F8"></navigation-bar>

<scroll-view scroll-y enable-flex class="page-wrap">
  <!-- 主卡：下次大姨妈 -->
  <widget-card title="{{ nextLineLabel }}" sub="{{ inProgressBadge }}" accent="{{ true }}">
    <view class="hero">
      <text class="hero-num">{{ daysToNext === null ? '—' : (daysToNext > 0 ? daysToNext : (daysToNext === 0 ? '今天' : '已超期')) }}</text>
      <text class="hero-unit" wx:if="{{ daysToNext !== null && daysToNext > 0 }}">天</text>
    </view>
    <view class="hero-sub">{{ nextDescribe }}<text wx:if="{{ predictedNextText !== '—' }}" class="hero-sub-date"> · {{ predictedNextText }}</text></view>
    <view class="row gap-24 hero-meta">
      <view class="meta">
        <view class="meta-k">上次大姨妈</view>
        <view class="meta-v">{{ lastDateText }}</view>
        <view class="meta-foot" wx:if="{{ lastSinceText }}">{{ lastSinceText }}</view>
      </view>
      <view class="meta">
        <view class="meta-k">平均周期</view>
        <view class="meta-v">{{ avgCycleText }}</view>
        <view class="meta-foot" wx:if="{{ stats.totalCycles }}">已记 {{ stats.totalCycles }} 个周期</view>
      </view>
    </view>
  </widget-card>

  <!-- CTA 按钮：横向并排 -->
  <view class="cta">
    <view class="cta-row">
      <view class="cta-cell">
        <view class="btn-primary cta-btn" bindtap="onMarkPeriodStart">今天来了</view>
      </view>
      <view class="cta-cell">
        <view class="btn-secondary cta-btn" bindtap="onMarkPeriodEnd">这次结束了</view>
      </view>
    </view>
  </view>

  <!-- 日历 -->
  <period-calendar
    period-events="{{ events }}"
    predicted-next-start="{{ predictedNextStart }}"
    bind:tap="onCalendarTap"
  />

  <!-- 本周期统计 -->
  <view class="card" wx:if="{{ stats }}">
    <view class="card-title">本周期</view>
    <view class="row-between">
      <view class="muted">共记录</view>
      <view>{{ cycleRecordCount }} 条</view>
    </view>
    <view class="row-between">
      <view class="muted">总周期数</view>
      <view>{{ stats.totalCycles }} 个</view>
    </view>
    <view class="row-between" wx:if="{{ stats.lastDurationDays !== null }}">
      <view class="muted">上次持续</view>
      <view>{{ stats.lastDurationDays }} 天</view>
    </view>
  </view>

  <!-- 备注 / 大姨妈 切换卡 -->
  <view class="card">
    <view class="tabs">
      <view
        class="tab {{ activeTab === 'note' ? 'tab-on' : '' }}"
        data-tab="note"
        bindtap="onTabChange"
      >📝 备注</view>
      <view
        class="tab {{ activeTab === 'cycle' ? 'tab-on' : '' }}"
        data-tab="cycle"
        bindtap="onTabChange"
      >🌹 大姨妈</view>
    </view>

    <!-- ===== Tab: 备注 ===== -->
    <block wx:if="{{ activeTab === 'note' }}">
      <view class="mood-entry" bindtap="onAddMoodNote">记录当下的心情</view>
      <view wx:if="{{ groups.length === 0 }}" class="empty">
        <view class="empty-emoji">🌸</view>
        <view class="empty-text">还没有心情记录</view>
      </view>
      <view wx:else class="timeline">
        <view class="day-group" wx:for="{{ groups }}" wx:key="dateKey" wx:for-item="g">
          <view class="day-head">
            <view class="day-label">{{ g.dateLabel }}</view>
            <view class="day-line"></view>
            <view class="day-count">{{ g.items.length }} 条</view>
          </view>
          <view
            wx:for="{{ g.items }}"
            wx:key="id"
            wx:for-item="item"
            class="day-item mood-item"
            data-id="{{ item.id }}"
            bindlongpress="onLongPressItem"
          >
            <view class="day-time mood-time">
              <view class="mood-day">{{ item.dayLabel }}</view>
              <view class="mood-clock">{{ item.timeLabel }}</view>
            </view>
            <view class="day-body">
              <view class="row-between">
                <recorder-badge label="{{ item.badge }}" isSelf="{{ item.isSelf }}" />
                <view class="tiny muted" wx:if="{{ batchMode && item.canDelete }}">长按可删除</view>
              </view>
              <view class="row-text">{{ item.text }}</view>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- ===== Tab: 大姨妈 ===== -->
    <block wx:else>
      <view wx:if="{{ cycles.length === 0 }}" class="empty">
        <view class="empty-emoji">🌹</view>
        <view class="empty-text">还没有记录过大姨妈</view>
      </view>
      <view wx:else class="cycle-list">
        <view class="cycle-card {{ c.ongoing ? 'cycle-ongoing' : '' }}" wx:for="{{ cycles }}" wx:key="id" wx:for-item="c" data-ids="{{ c.recordEventIdsText }}" bindlongpress="onLongPressCycleCard">
          <view class="cycle-row">
            <view class="cycle-dot"></view>
            <view class="cycle-range">
              <text class="cycle-start">{{ c.startLabel }}</text>
              <text class="cycle-tilde">　～　</text>
              <text class="cycle-end {{ c.ongoing ? 'cycle-end-ongoing' : '' }}">{{ c.endLabel }}</text>
            </view>
          </view>
          <view class="cycle-meta">
            <view class="cycle-duration">{{ c.durationLabel }}</view>
            <view class="tiny muted" wx:if="{{ batchMode }}">长按可删除</view>
            <picker
              wx:if="{{ !batchMode && (c.ongoing || c.endLabel === '未记结束') }}"
              mode="date"
              start="{{ c.startDate }}"
              end="{{ todayStr }}"
              value="{{ todayStr }}"
              data-start-date="{{ c.startDate }}"
              data-batch-id="{{ c.batchId }}"
              bindchange="onSetEndDate"
            >
              <view class="cycle-action">⏱ 去记结束和详情</view>
            </picker>
          </view>

          <view wx:if="{{ c.records.length > 0 }}" class="cycle-notes-wrap">
            <view class="cycle-notes-toggle" data-id="{{ c.id }}" bindtap="onToggleCycle">
              <text class="cycle-toggle-icon">{{ c.expanded ? '▼' : '▶' }}</text>
              <text>本期相关记录 {{ c.records.length }} 条</text>
            </view>
            <view wx:if="{{ c.expanded }}" class="cycle-notes">
              <view class="cycle-note" wx:for="{{ c.records }}" wx:key="id" wx:for-item="n" data-ids="{{ n.eventIdsText }}" bindlongpress="onLongPressCycleRecord">
                <view class="cycle-note-head">
                  <view class="cycle-note-when">{{ n.dateLabel }} {{ n.timeLabel }}</view>
                </view>
                <view class="cycle-note-body">
                  <view class="cycle-note-text" wx:for="{{ n.lines }}" wx:key="*this" wx:for-item="line">{{ line }}</view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 未来 widgets 占位 -->
  <view class="future">未来会加：账本 · 孩子记录 · 共同清单</view>

  <!-- mock 模式提示 -->
  <view wx:if="{{ isMock }}" class="mock-hint">
    🛠 当前为 Mock 模式（云开发未配置）。开通云开发后改 constants.ts 的 CLOUD_ENV
  </view>
</scroll-view>

<!-- Undo 浮层 -->
<view class="undo-bar" wx:if="{{ showUndo }}">
  <text class="undo-text">5 秒内可撤销</text>
  <view class="undo-btn" bindtap="onUndo">撤销</view>
</view>
