<navigation-bar title="记一笔" back="{{ false }}" color="#2C2C2C" background="#FFF7F8"></navigation-bar>

<scroll-view scroll-y enable-flex class="page-wrap">

  <view class="card">
    <view class="card-title">什么时候</view>
    <view class="seg-row">
      <view class="seg {{ timeMode === 'now' ? 'seg-on' : '' }}" bindtap="onUseNow">现在</view>
      <view class="seg {{ timeMode === 'range' ? 'seg-on' : '' }}" bindtap="onUseDateRange">选择日期</view>
    </view>
  </view>

  <!-- 选了"选择日期"后再展开一张全宽的日期面板，避免半宽卡片里挤不下 -->
  <view wx:if="{{ timeMode === 'range' }}" class="card">
    <view class="card-title">日期范围</view>
    <view class="range-panel">
      <view class="card-sub">
        💡 选好后会作为老婆的「大姨妈周期」记到周期页；只填开始也行，结束日期可以以后再补。
      </view>

      <view class="seg-row range-row">
        <picker class="seg-wrap" mode="date" value="{{ periodStartDate }}" end="{{ todayDate }}" bindchange="onPeriodStartDateChange">
          <view class="seg seg-block {{ periodStartDate ? 'seg-on' : '' }}">
            🌹 {{ periodStartLabel || '选择开始日期' }}
          </view>
        </picker>
        <picker class="seg-wrap" mode="date" value="{{ periodEndDate }}" start="{{ periodStartDate }}" end="{{ todayDate }}" bindchange="onPeriodEndDateChange">
          <view class="seg seg-block {{ periodEndDate ? 'seg-on' : '' }}">
            ✅ {{ periodEndLabel || '选择结束日期' }}
          </view>
        </picker>
      </view>

      <view wx:if="{{ periodStartDate || periodEndDate }}" class="row clear-row">
        <view wx:if="{{ periodStartDate }}" class="text-btn" bindtap="onClearPeriodStart">✕ 清空开始</view>
        <view wx:if="{{ periodEndDate }}" class="text-btn" bindtap="onClearPeriodEnd">✕ 清空结束</view>
      </view>
    </view>
  </view>

  <!-- 不适标签 -->
  <view class="card">
    <view class="card-title">不适标签</view>
    <view class="card-sub">点一下选中（默认 2/5），再点逐级提高，超过 5 取消</view>
    <view class="chips">
      <view
        wx:for="{{ symptomTags }}"
        wx:key="key"
        wx:for-item="tag"
        class="chip {{ selectedSymptoms[tag.key] ? 'chip-active' : '' }}"
        data-key="{{ tag.key }}"
        bindtap="onSymptomTap"
      >
        <text>{{ tag.emoji }} {{ tag.label }}</text>
        <text wx:if="{{ selectedSymptoms[tag.key] }}" class="sev"> · {{ selectedSymptoms[tag.key] }}/5</text>
      </view>
    </view>
  </view>

  <!-- 流量 -->
  <view class="card">
    <view class="card-title">流量</view>
    <view class="chips">
      <view
        wx:for="{{ flowLevels }}"
        wx:key="key"
        wx:for-item="lv"
        class="chip {{ selectedFlow === lv.key ? 'chip-active' : '' }}"
        data-key="{{ lv.key }}"
        bindtap="onFlowTap"
      >{{ lv.label }}</view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="card">
    <view class="card-title">备注（经期情况 / 用药 / 运动 / 睡眠 等）</view>
    <textarea
      class="ta"
      maxlength="500"
      placeholder="比如：下午开始疼，不算重，准备多喝热水"
      value="{{ noteText }}"
      bindinput="onNoteInput"
      auto-height
    />
    <view class="tiny muted right">{{ noteText.length }}/500</view>
  </view>

  <button class="btn-primary submit" bindtap="onSubmit" disabled="{{ submitting }}">
    {{ submitting ? '保存中…' : '保存这笔' }}
  </button>

  <view class="hint">
    💡 V1：本页采用快速标签录入。AI 自然语言录入将在 V1.1 加入（在这里加一个「自由说一句」输入框）。
  </view>

</scroll-view>
